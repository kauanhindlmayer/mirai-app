{
    "name": "mirai-app",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check": "vue-tsc --build --force",
        "lint": "eslint --ext \".js,.vue\" --ignore-path .gitignore . --cache",
        "lint:fix": "eslint --fix --ext \".js,.vue\" --ignore-path .gitignore .",
        "format": "prettier --write \"**/*.{js,vue,d.ts}\" --cache",
        "format:check": "prettier --check \"**/*.{js,vue,d.ts}\""
    },
    "dependencies": {
        "@primevue/forms": "^4.2.4",
        "@primevue/themes": "^4.2.4",
        "axios": "^1.7.9",
        "chart.js": "^4.4.7",
        "chartjs-adapter-date-fns": "^3.0.0",
        "pinia": "^2.3.0",
        "primeicons": "^7.0.0",
        "primevue": "^4.2.4",
        "quill": "^2.0.3",
        "ts-node": "^10.9.2",
        "vue": "^3.5.13",
        "vue-router": "^4.5.0",
        "yup": "^1.5.0"
    },
    "devDependencies": {
        "@primevue/auto-import-resolver": "^4.2.4",
        "@rushstack/eslint-patch": "^1.10.4",
        "@tsconfig/node20": "^20.1.4",
        "@types/node": "^22.10.1",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vue/eslint-config-prettier": "^10.1.0",
        "@vue/eslint-config-typescript": "^14.1.4",
        "@vue/tsconfig": "^0.7.0",
        "autoprefixer": "^10.4.20",
        "eslint": "^9.16.0",
        "eslint-plugin-vue": "^9.32.0",
        "npm-run-all2": "^7.0.1",
        "postcss": "^8.4.49",
        "prettier": "^3.4.2",
        "sass": "^1.82.0",
        "tailwindcss": "^3.4.16",
        "tailwindcss-primeui": "^0.3.4",
        "typescript": "~5.4.0",
        "unplugin-vue-components": "^0.27.5",
        "vite": "^6.0.3",
        "vite-plugin-vue-devtools": "^7.6.7",
        "vue-tsc": "^2.1.10"
    }
}

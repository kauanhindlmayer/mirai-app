{
  "name": "mirai-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@microsoft/signalr": "^8.0.17",
    "@pinia/colada": "^1.3.1",
    "@pinia/colada-plugin-delay": "^0.1.5",
    "@primeuix/themes": "^1.2.5",
    "@primevue/forms": "^4.5.5",
    "@tailwindcss/vite": "^4.3.2",
    "@vueuse/core": "^12.8.2",
    "@vueuse/router": "^12.8.2",
    "axios": "^1.18.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.4.0",
    "dotenv": "^16.6.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "quill": "^2.0.3",
    "vue": "^3.5.39",
    "vue-meta": "3.0.0-alpha.10",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.61.1",
    "@primevue/auto-import-resolver": "^4.5.5",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.20.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/eslint-plugin": "1.1.10",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-oxlint": "^0.11.1",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.11.1",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-primeui": "^0.5.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^0.27.5",
    "unplugin-vue-router": "^0.11.2",
    "vite": "^6.4.3",
    "vite-plugin-vue-devtools": "^7.7.10",
    "vitest": "^3.2.6",
    "vue-tsc": "^2.2.12"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "oxlint . --fix -D correctness --ignore-path .gitignore"
    ],
    "*.{js,ts,vue,json,md,html,css,scss}": [
      "prettier --write"
    ]
  }
}
